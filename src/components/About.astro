---
const pillars = [
  { label: 'Trayectoria industrial', desc: 'Ex-mantenimiento Bagley',       icon: '🏭' },
  { label: 'Bajo normativa',         desc: 'Trabajos seguros y certificados', icon: '📋' },
  { label: 'Trato familiar',         desc: 'Atención personalizada',          icon: '🤝' },
  { label: 'Trabajo prolijo',        desc: 'Detalle y precisión garantizados',icon: '🔍' },
];
---

<section id="trayectoria" class="relative py-28 overflow-hidden" style="background:#1A1A1A;">

  <div class="absolute top-0 left-0 right-0 h-px" style="background:linear-gradient(90deg,transparent,rgba(46,46,46,1),transparent);"></div>

  <!-- Decorative bolt -->
  <div class="absolute right-0 bottom-0 opacity-[0.025] pointer-events-none select-none overflow-hidden">
    <svg width="580" height="660" viewBox="0 0 24 24" fill="#FF8C00" aria-hidden="true">
      <path d="M13 2L4.09 12.97H11L10 22l8.91-10.97H13L13 2z"/>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-5 lg:px-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Text -->
      <div>
        <div class="flex items-center gap-3 mb-5">
          <span class="w-8 h-px bg-brand-orange"></span>
          <span class="text-brand-orange text-[10px] font-body font-600 tracking-widest uppercase">Nuestra Trayectoria</span>
        </div>

        <h2 class="font-display font-800 text-4xl md:text-5xl lg:text-6xl text-brand-white leading-tight mb-6 tracking-tight">
          EXPERIENCIA<br />QUE SE <span class="text-brand-orange">NOTA.</span>
        </h2>

        <p class="text-brand-silver text-base lg:text-lg font-body font-300 leading-relaxed mb-5">
          Somos un equipo familiar de técnicos electricistas con amplia trayectoria en
          mantenimiento industrial <strong class="text-brand-light font-500">(ex-mantenimiento Bagley)</strong>.
        </p>
        <p class="text-brand-silver text-base lg:text-lg font-body font-300 leading-relaxed mb-10">
          Nuestra experiencia en entornos de alta exigencia nos permite garantizar trabajos
          <strong class="text-brand-light font-500">seguros, prolijos y bajo normativa vigente</strong> —
          tanto en hogares como en comercios de Salto y zona.
        </p>

        <a
          href="https://wa.me/5492474472101?text=Hola!%20Quiero%20hablar%20con%20un%20técnico."
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-6 py-3.5 border text-brand-orange hover:text-brand-white hover:border-brand-orange font-display font-600 text-base tracking-wide uppercase rounded transition-all duration-200 group"
          style="border-color:rgba(255,140,0,0.4);"
        >
          Hablá con un técnico
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <!-- Pillars grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {pillars.map(p => (
          <div
            class="group p-6 rounded-xl border transition-all duration-300"
            style="background:#222222;border-color:#2E2E2E;"
            onmouseenter="this.style.borderColor='rgba(255,140,0,0.3)';this.style.background='#262626';"
            onmouseleave="this.style.borderColor='#2E2E2E';this.style.background='#222222';"
          >
            <span class="text-2xl block mb-3">{p.icon}</span>
            <h3 class="font-display font-700 text-lg text-brand-light mb-1 tracking-tight">{p.label}</h3>
            <p class="text-brand-muted text-sm font-body font-300">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Quote -->
    <div class="mt-20 border-t pt-10 text-center" style="border-color:#2E2E2E;">
      <blockquote>
        <p class="font-display font-700 text-2xl md:text-3xl text-brand-white leading-snug tracking-tight">
          "Seriedad, confianza y <span class="text-brand-orange">seguridad eléctrica.</span>"
        </p>
        <cite class="mt-3 block text-brand-muted text-xs font-body not-italic tracking-widest uppercase">
          — Ñañez &amp; Co. Electricidad
        </cite>
      </blockquote>
    </div>
  </div>
</section>
