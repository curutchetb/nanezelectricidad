---
const WA = 'https://wa.me/5492474472101?text=Hola!%20Quiero%20hablar%20con%20un%20técnico.';

const pillars = [
  { icon: '🏭', label: 'Trayectoria industrial',  desc: 'Ex-mantenimiento Bagley (planta de alta exigencia)' },
  { icon: '📋', label: 'Matriculado habilitado',   desc: 'Trabajos certificados bajo normativa vigente AEA' },
  { icon: '🤝', label: 'Empresa familiar',         desc: 'Vecinos de Salto. Trato cercano y responsable' },
  { icon: '🔍', label: 'Trabajo prolijo',          desc: 'Cada instalación, terminada como si fuera propia' },
];
---

<section id="trayectoria" class="relative py-24 lg:py-32 overflow-hidden" style="background:#1A1A1A;">

  <div class="absolute top-0 left-0 right-0 h-px" style="background:linear-gradient(90deg,transparent,#2A2A2A,transparent);"></div>

  <!-- Decorative bolt bg -->
  <div class="absolute right-0 bottom-0 opacity-[0.025] pointer-events-none select-none overflow-hidden">
    <svg width="600" height="680" viewBox="0 0 24 24" fill="#FF8C00" aria-hidden="true">
      <path d="M13 2L4.09 12.97H11L10 22l8.91-10.97H13L13 2z"/>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-5 lg:px-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 lg:gap-20 items-center">

      <!-- Text -->
      <div>
        <div class="flex items-center gap-3 mb-5">
          <span class="w-8 h-0.5 rounded-full" style="background:#FF8C00;"></span>
          <span class="text-[10px] font-body font-600 tracking-widest uppercase" style="color:#FF8C00;">Quiénes Somos</span>
        </div>

        <h2 class="font-display font-700 text-4xl md:text-5xl lg:text-[56px] text-brand-white leading-[.95] tracking-tight mb-6">
          EXPERIENCIA<br />
          QUE SE <span class="text-gradient">NOTA.</span>
        </h2>

        <p class="text-brand-silver text-base lg:text-lg font-body font-300 leading-relaxed mb-5">
          Somos un equipo familiar de técnicos electricistas con amplia trayectoria en
          mantenimiento industrial —
          <strong class="text-brand-light font-500">ex-personal de mantenimiento Bagley</strong>.
        </p>
        <p class="text-brand-silver text-base lg:text-lg font-body font-300 leading-relaxed mb-10">
          Esa experiencia en entornos de alta exigencia es lo que traemos a cada trabajo en Salto,
          Pergamino, Arrecifes: instalaciones <strong class="text-brand-light font-500">seguras,
          prolijas y bajo normativa vigente.</strong>
        </p>

        <a
          href={WA}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-6 py-3.5 rounded-xl border font-body font-500 text-sm tracking-wide transition-all duration-300 group"
          style="border-color:rgba(255,140,0,.35);color:#FF8C00;"
          onmouseenter="this.style.background='rgba(255,140,0,0.08)';this.style.borderColor='rgba(255,140,0,.6)';"
          onmouseleave="this.style.background='transparent';this.style.borderColor='rgba(255,140,0,.35)';"
        >
          Hablá con nosotros
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <!-- Pillars -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {pillars.map(p => (
          <div
            class="card-glow p-6 rounded-2xl border"
            style="background:#111111;border-color:#2A2A2A;"
          >
            <span class="text-2xl block mb-3">{p.icon}</span>
            <h3 class="font-display font-600 text-lg text-brand-light mb-1 tracking-tight">{p.label}</h3>
            <p class="text-brand-muted text-sm font-body font-300 leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Blockquote / slogan -->
    <div class="mt-20 border-t pt-10 text-center" style="border-color:#2A2A2A;">
      <blockquote>
        <p class="font-display font-600 text-2xl md:text-3xl lg:text-4xl text-brand-white leading-snug">
          "Seriedad, confianza y<br />
          <span class="text-gradient">seguridad eléctrica.</span>"
        </p>
        <cite class="mt-4 block text-brand-muted text-xs font-body not-italic tracking-widest uppercase">
          — Ñañez &amp; Co. Electricidad · Salto, Buenos Aires
        </cite>
      </blockquote>
    </div>
  </div>
</section>