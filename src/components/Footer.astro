---
const navLinks = [
  { href: '#inicio',      label: 'Inicio' },
  { href: '#servicios',   label: 'Servicios' },
  { href: '#trayectoria', label: 'Trayectoria' },
];
const coverage = ['Salto', 'Pergamino', 'Arrecifes', 'Rojas', 'Zona de influencia'];
---

<footer id="contacto" class="relative overflow-hidden" style="background:#0F0F0F;border-top:1px solid #2E2E2E;">

  <div class="absolute inset-0 pointer-events-none opacity-[0.03]"
    style="background-image:linear-gradient(rgba(180,180,180,.4) 1px,transparent 1px),linear-gradient(90deg,rgba(180,180,180,.4) 1px,transparent 1px);background-size:48px 48px;"></div>

  <div class="relative max-w-7xl mx-auto px-5 lg:px-10 py-16 lg:py-20">

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-14">

      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="#inicio" class="inline-block mb-5" aria-label="Ñañez & Co. Electricidad">
          <img
            src="./logo.png"
            alt="Ñañez & Co. Electricidad"
            width="200"
            height="52"
            class="h-10 w-auto object-contain"
            loading="lazy"
          />
        </a>
        <p class="text-brand-muted text-sm font-body font-300 leading-relaxed max-w-xs mb-6">
          Seriedad, confianza y seguridad eléctrica. Servicio residencial e industrial
          en Salto y zona con calidad garantizada.
        </p>

        <!-- Socials -->
        <div class="flex gap-3">
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer"
            aria-label="Instagram de Ñañez & Co."
            class="w-9 h-9 rounded-lg flex items-center justify-center transition-all duration-200"
            style="background:#2E2E2E;"
            onmouseenter="this.style.background='#FF8C00';this.querySelector('svg').style.color='#fff';"
            onmouseleave="this.style.background='#2E2E2E';this.querySelector('svg').style.color='#888888';"
          >
            <svg class="w-4 h-4 transition-colors" style="color:#888888;" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a href="https://facebook.com" target="_blank" rel="noopener noreferrer"
            aria-label="Facebook de Ñañez & Co."
            class="w-9 h-9 rounded-lg flex items-center justify-center transition-all duration-200"
            style="background:#2E2E2E;"
            onmouseenter="this.style.background='#FF8C00';this.querySelector('svg').style.color='#fff';"
            onmouseleave="this.style.background='#2E2E2E';this.querySelector('svg').style.color='#888888';"
          >
            <svg class="w-4 h-4 transition-colors" style="color:#888888;" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://wa.me/5492474472101" target="_blank" rel="noopener noreferrer"
            aria-label="WhatsApp de Ñañez & Co."
            class="w-9 h-9 rounded-lg flex items-center justify-center transition-all duration-200"
            style="background:#2E2E2E;"
            onmouseenter="this.style.background='#25D366';this.querySelector('svg').style.color='#fff';"
            onmouseleave="this.style.background='#2E2E2E';this.querySelector('svg').style.color='#888888';"
          >
            <svg class="w-4 h-4 transition-colors" style="color:#888888;" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav -->
      <div>
        <h4 class="font-display font-700 text-xs text-brand-light tracking-widest uppercase mb-5">Navegación</h4>
        <ul class="space-y-3">
          {navLinks.map(l => (
            <li><a href={l.href} class="text-brand-muted hover:text-brand-orange text-sm font-body transition-colors duration-200">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Coverage -->
      <div>
        <h4 class="font-display font-700 text-xs text-brand-light tracking-widest uppercase mb-5">Cobertura</h4>
        <ul class="space-y-2">
          {coverage.map(c => (
            <li class="flex items-center gap-2 text-brand-muted text-sm font-body font-300">
              <span class="w-1 h-1 rounded-full bg-brand-orange flex-shrink-0"></span>
              {c}
            </li>
          ))}
        </ul>
        <p class="mt-5 text-brand-muted text-xs font-body font-300">📍 Salto, Buenos Aires</p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t pt-7 flex flex-col sm:flex-row justify-between items-center gap-3" style="border-color:#2E2E2E;">
      <p class="text-brand-muted/60 text-xs font-body font-300">
        &copy; {new Date().getFullYear()} Ñañez &amp; Co. Electricidad. Todos los derechos reservados.
      </p>
      <p class="text-brand-muted/40 text-xs font-body font-300">Diseño web ⚡</p>
    </div>
  </div>
</footer>

<!-- Floating WhatsApp -->
<a
  href="https://wa.me/5492474472101?text=Hola!%20Necesito%20un%20servicio%20eléctrico."
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] hover:bg-[#20BB5A] rounded-full flex items-center justify-center shadow-lg transition-all duration-300 hover:scale-110 animate-pulse-glow"
  style="box-shadow:0 4px 20px rgba(37,211,102,0.35);"
  aria-label="Contactar por WhatsApp"
>
  <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>
