---
const WA = 'https://wa.me/5492474472101?text=Hola!%20Necesito%20un%20servicio%20eléctrico.';
const navLinks = [
  { href: '#inicio',      label: 'Inicio' },
  { href: '#servicios',   label: 'Servicios' },
  { href: '#trayectoria', label: 'Trayectoria' },
  { href: '#trabajos',    label: 'Trabajos' },
];
const coverage = ['Salto', 'Pergamino', 'Arrecifes', 'Rojas', 'Zona norte Bs.As.'];
---

<footer id="contacto" class="relative overflow-hidden" style="background:#080808;border-top:1px solid #2A2A2A;">

  <!-- Grid texture -->
  <div class="absolute inset-0 pointer-events-none opacity-[0.025]"
    style="background-image:linear-gradient(rgba(200,200,200,.5) 1px,transparent 1px),linear-gradient(90deg,rgba(200,200,200,.5) 1px,transparent 1px);background-size:48px 48px;"></div>

  <div class="relative max-w-7xl mx-auto px-5 lg:px-10 py-16 lg:py-20">

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-14">

      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="#inicio" class="inline-block mb-5" aria-label="Ñañez & Co. Electricidad">
          <img
            src="./logo.webp"
            alt="Ñañez & Co. Electricidad – Electricista matriculado en Salto"
            width="200"
            height="55"
            class="h-10 w-auto object-contain"
            loading="lazy"
          />
        </a>
        <p class="text-brand-muted text-sm font-body font-300 leading-relaxed max-w-xs mb-6">
          Electricista matriculado en Salto, Buenos Aires. Instalaciones residenciales,
          comerciales e industriales con seriedad y seguridad.
        </p>

        <!-- Contact info -->
        <div class="space-y-2 mb-6">
          <a
            href={WA}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm font-body font-400 text-brand-silver hover:text-brand-orange transition-colors duration-200"
          >
            <svg class="w-4 h-4 text-brand-orange flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            +54 9 2474 47-2101
          </a>
          <p class="flex items-center gap-2 text-sm font-body font-300 text-brand-muted">
            <svg class="w-4 h-4 text-brand-orange flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            Salto, Buenos Aires
          </p>
        </div>

        <!-- Socials -->
        <div class="flex gap-3">
          {[
            {
              label: 'Instagram',
              href: 'https://instagram.com/nanezelectricidad',
              icon: `<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>`,
            },
            {
              label: 'Facebook',
              href: 'https://facebook.com/nanezelectricidad',
              icon: `<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>`,
            },
          ].map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${s.label} de Ñañez & Co.`}
              class="w-9 h-9 rounded-lg flex items-center justify-center transition-all duration-200"
              style="background:#1A1A1A;border:1px solid #2A2A2A;"
              onmouseenter="this.style.borderColor='rgba(255,140,0,.4)';this.style.background='rgba(255,140,0,0.1)';"
              onmouseleave="this.style.borderColor='#2A2A2A';this.style.background='#1A1A1A';"
            >
              <svg class="w-4 h-4" style="color:#777777;" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={s.icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Nav -->
      <div>
        <h4 class="font-display font-600 text-xs text-brand-light tracking-widest uppercase mb-5">Navegación</h4>
        <ul class="space-y-3">
          {navLinks.map(l => (
            <li>
              <a href={l.href} class="text-brand-muted hover:text-brand-orange text-sm font-body font-300 transition-colors duration-200">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Coverage -->
      <div>
        <h4 class="font-display font-600 text-xs text-brand-light tracking-widest uppercase mb-5">Zona de Cobertura</h4>
        <ul class="space-y-2">
          {coverage.map(c => (
            <li class="flex items-center gap-2 text-brand-muted text-sm font-body font-300">
              <span class="w-1 h-1 rounded-full flex-shrink-0" style="background:#FF8C00;"></span>
              {c}
            </li>
          ))}
        </ul>
        <div class="mt-5 p-4 rounded-xl border space-y-2" style="background:#111111;border-color:#2A2A2A;">
          <p class="text-xs font-body font-300 text-brand-muted">Lunes a sábado</p>
          <p class="text-xs font-body font-300 text-brand-muted">Atención rápida ante imprevistos</p>
          <a href={WA} target="_blank" rel="noopener noreferrer"
            class="mt-1 block text-xs font-body font-500 text-brand-orange hover:text-brand-orangeLight transition-colors duration-200">
            Escribir por WhatsApp →
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t pt-7 flex flex-col sm:flex-row justify-between items-center gap-3" style="border-color:#1A1A1A;">
      <p class="text-[11px] font-body font-300" style="color:rgba(119,119,119,.6);">
        &copy; {new Date().getFullYear()} Ñañez &amp; Co. Electricidad · Salto, Buenos Aires · Todos los derechos reservados.
      </p>
      <p class="text-[11px] font-body font-300" style="color:rgba(119,119,119,.35);">Electricista matriculado Pcia. de Bs.As.</p>
    </div>
  </div>
</footer>

<!-- Floating WhatsApp -->
<a
  href={WA}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full flex items-center justify-center transition-all duration-300 hover:scale-110"
  style="background:#25D366;box-shadow:0 4px 24px rgba(37,211,102,.4);"
  aria-label="Contactar a Ñañez Electricidad por WhatsApp"
>
  <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>