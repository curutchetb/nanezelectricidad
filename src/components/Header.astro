---
const navLinks = [
  { href: '#inicio',      label: 'Inicio' },
  { href: '#servicios',   label: 'Servicios' },
  { href: '#trayectoria', label: 'Trayectoria' },
  { href: '#trabajos',    label: 'Trabajos' },
  { href: '#contacto',    label: 'Contacto' },
];
const WA = 'https://wa.me/5492474472101?text=Hola!%20Quiero%20solicitar%20un%20presupuesto.';
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <div class="max-w-7xl mx-auto px-5 lg:px-10">
    <div class="flex items-center justify-between h-16 lg:h-[72px]">

      <!-- Logo — prominente pero no invasivo -->
      <a href="#inicio" class="flex-shrink-0 group" aria-label="Ñañez & Co. Electricidad">
        <img
          src="/logo.webp"
          alt="Ñañez & Co. Electricidad – Salto, Buenos Aires"
          width="220"
          height="60"
          class="h-11 lg:h-14 w-auto object-contain drop-shadow-[0_2px_8px_rgba(255,140,0,0.25)] group-hover:drop-shadow-[0_2px_16px_rgba(255,140,0,0.5)] transition-all duration-300"
          loading="eager"
          fetchpriority="high"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-7" aria-label="Navegación principal">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-[13px] font-body font-500 text-brand-silver hover:text-brand-orange transition-colors duration-200 relative group tracking-wide"
          >
            {link.label}
            <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-brand-orange group-hover:w-full transition-all duration-300 rounded-full"></span>
          </a>
        ))}
        <a
          href={WA}
          target="_blank"
          rel="noopener noreferrer"
          class="ml-1 flex items-center gap-2 px-5 py-2.5 text-white text-[13px] font-body font-600 tracking-wide rounded-lg transition-all duration-200 animate-glow-btn"
          style="background: linear-gradient(135deg, #FF8C00, #CC7000);"
        >
          <!-- WA icon -->
          <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Consultar
        </a>
      </nav>

      <!-- Mobile: WA button + hamburger -->
      <div class="lg:hidden flex items-center gap-3">
        <a
          href={WA}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-white text-xs font-body font-600"
          style="background:linear-gradient(135deg,#FF8C00,#CC7000);"
          aria-label="Contactar por WhatsApp"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
        <button id="menu-toggle" class="flex flex-col gap-1.5 p-1.5" aria-label="Abrir menú" aria-expanded="false">
          <span class="w-5 h-0.5 bg-brand-light block transition-all duration-300" id="bar1"></span>
          <span class="w-3.5 h-0.5 bg-brand-light block transition-all duration-300" id="bar2"></span>
          <span class="w-5 h-0.5 bg-brand-light block transition-all duration-300" id="bar3"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t" style="background:#111111;border-color:#2A2A2A;">
    <nav class="flex flex-col px-5 py-3 gap-0.5" aria-label="Menú móvil">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="mobile-link py-3 text-brand-silver hover:text-brand-orange font-body font-500 text-sm border-b transition-colors duration-200"
          style="border-color:#2A2A2A;"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('bg-brand-dark/96', 'backdrop-blur-xl',
        'shadow-[0_1px_0_rgba(255,140,0,0.15),0_4px_24px_rgba(0,0,0,0.6)]');
    } else {
      header?.classList.remove('bg-brand-dark/96', 'backdrop-blur-xl',
        'shadow-[0_1px_0_rgba(255,140,0,0.15),0_4px_24px_rgba(0,0,0,0.6)]');
    }
  }, { passive: true });

  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!open));
  });
  document.querySelectorAll('.mobile-link').forEach(l =>
    l.addEventListener('click', () => menu?.classList.add('hidden'))
  );
</script>