---
const navLinks = [
  { href: '#inicio',      label: 'Inicio' },
  { href: '#servicios',   label: 'Servicios' },
  { href: '#trayectoria', label: 'Trayectoria' },
  { href: '#contacto',    label: 'Contacto' },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-5 lg:px-10">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo real -->
      <a href="#inicio" class="flex-shrink-0 group" aria-label="Ñañez & Co. Electricidad - Inicio">
        <img
          src="/nanezelectricidad/public/logo.png"
          alt="Ñañez & Co. Electricidad"
          width="200"
          height="52"
          class="h-10 lg:h-12 w-auto object-contain brightness-100 group-hover:brightness-110 transition-all duration-300"
          loading="eager"
        />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-6 lg:gap-8" aria-label="Navegación principal">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-sm font-body font-500 text-brand-silver hover:text-brand-orange transition-colors duration-200 relative group"
          >
            {link.label}
            <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-brand-orange group-hover:w-full transition-all duration-300"></span>
          </a>
        ))}
        <a
          href="https://wa.me/5492474472101?text=Hola!%20Quiero%20solicitar%20un%20presupuesto."
          target="_blank"
          rel="noopener noreferrer"
          class="ml-2 px-5 py-2.5 bg-brand-orange hover:bg-brand-orangeHover text-white text-sm font-display font-700 tracking-wide uppercase rounded transition-colors duration-200 animate-pulse-glow"
        >
          Presupuesto
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        class="md:hidden flex flex-col gap-1.5 p-2"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <span id="bar1" class="w-6 h-0.5 bg-brand-light transition-all duration-300 block"></span>
        <span id="bar2" class="w-4 h-0.5 bg-brand-light transition-all duration-300 block"></span>
        <span id="bar3" class="w-6 h-0.5 bg-brand-light transition-all duration-300 block"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-brand-charcoal border-t border-brand-steel/60">
    <nav class="flex flex-col px-5 py-4 gap-1" aria-label="Menú móvil">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="mobile-link py-3 text-brand-silver hover:text-brand-orange font-body font-500 border-b border-brand-steel/40 last:border-0 transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://wa.me/5492474472101?text=Hola!%20Quiero%20solicitar%20un%20presupuesto."
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 text-center px-5 py-3 bg-brand-orange text-white font-display font-700 tracking-wide uppercase rounded"
      >
        Solicitar Presupuesto
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('bg-brand-dark/95', 'backdrop-blur-md', 'shadow-lg', 'shadow-black/60', 'border-b', 'border-brand-steel/40');
    } else {
      header?.classList.remove('bg-brand-dark/95', 'backdrop-blur-md', 'shadow-lg', 'shadow-black/60', 'border-b', 'border-brand-steel/40');
    }
  }, { passive: true });

  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
  document.querySelectorAll('.mobile-link').forEach(l =>
    l.addEventListener('click', () => menu?.classList.add('hidden'))
  );
</script>
