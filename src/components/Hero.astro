---
const WA = 'https://wa.me/5492474472101?text=Hola!%20Quiero%20solicitar%20un%20presupuesto.';
const stats = [
  { value: '15+', label: 'Años de experiencia' },
  { value: '4',   label: 'Localidades cubiertas' },
  { value: '✓',   label: 'Matriculado habilitado' },
];
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center overflow-hidden pt-20"
  aria-label="Inicio – Ñañez & Co. Electricidad"
>
  <!-- Background layers -->
  <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 60% 40%, rgba(255,140,0,0.07) 0%, transparent 60%), linear-gradient(160deg, #0D0D0D 0%, #111111 40%, #1A1A1A 100%);"></div>

  <!-- Grid texture -->
  <div class="absolute inset-0 opacity-[0.04]"
    style="background-image:linear-gradient(rgba(200,200,200,.5) 1px,transparent 1px),linear-gradient(90deg,rgba(200,200,200,.5) 1px,transparent 1px);background-size:56px 56px;">
  </div>

  <!-- Orange accent line top -->
  <div class="absolute top-0 left-0 right-0 h-[2px]"
    style="background:linear-gradient(90deg,transparent 0%,#FF8C00 40%,#FFD700 60%,transparent 100%);">
  </div>

  <!-- Large decorative bolt -->
  <div class="absolute right-[-4rem] top-1/2 -translate-y-1/2 opacity-[0.035] pointer-events-none select-none">
    <svg width="560" height="640" viewBox="0 0 24 24" fill="#FF8C00" aria-hidden="true">
      <path d="M13 2L4.09 12.97H11L10 22l8.91-10.97H13L13 2z"/>
    </svg>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-5 lg:px-10 py-20 lg:py-28">
    <div class="max-w-3xl">

      <!-- Location badge -->
      <div
        class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-7 opacity-0 animate-fade-in"
        style="animation-delay:.08s;animation-fill-mode:forwards;background:rgba(255,140,0,.1);border:1px solid rgba(255,140,0,.3);"
      >
        <svg class="w-3 h-3 text-brand-orange flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
        </svg>
        <span class="text-brand-orange text-[10px] font-body font-600 tracking-widest uppercase">
          Electricista matriculado · Salto, Buenos Aires
        </span>
      </div>

      <!-- Headline -->
      <h1
        class="font-display font-700 text-[52px] md:text-[72px] lg:text-[88px] text-brand-white leading-[.9] tracking-tight mb-6 opacity-0 animate-fade-up"
        style="animation-delay:.18s;animation-fill-mode:forwards;"
      >
        SOLUCIONES<br />
        <span class="text-gradient-animated">ELÉCTRICAS</span><br />
        CON RESPALDO<br />
        <span class="text-brand-light">INDUSTRIAL.</span>
      </h1>

      <!-- Sub -->
      <p
        class="text-brand-silver text-base md:text-lg lg:text-xl font-body font-300 leading-relaxed max-w-[520px] mb-10 opacity-0 animate-fade-up"
        style="animation-delay:.3s;animation-fill-mode:forwards;"
      >
        Vecinos de Salto. Llevamos la exigencia del mantenimiento industrial
        a <strong class="text-brand-light font-500">tu hogar o comercio</strong> —
        instalaciones seguras, prolijas y bajo normativa vigente.
      </p>

      <!-- CTAs -->
      <div
        class="flex flex-col sm:flex-row gap-4 mb-16 opacity-0 animate-fade-up"
        style="animation-delay:.42s;animation-fill-mode:forwards;"
      >
        <a
          href={WA}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center justify-center gap-3 px-8 py-4 text-white font-body font-600 text-base tracking-wide rounded-xl transition-all duration-300 animate-glow-btn"
          style="background:linear-gradient(135deg,#FF8C00 0%,#CC7000 100%);"
        >
          <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Pedir Presupuesto por WhatsApp
        </a>
        <a
          href="#servicios"
          class="flex items-center justify-center gap-2 px-8 py-4 border text-brand-light hover:text-brand-orange hover:border-brand-orange font-body font-500 text-base tracking-wide rounded-xl transition-all duration-300"
          style="border-color:#383838;"
        >
          Ver Servicios
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <!-- Stats row -->
      <div
        class="flex flex-wrap gap-8 border-t pt-8 opacity-0 animate-fade-up"
        style="animation-delay:.55s;animation-fill-mode:forwards;border-color:rgba(42,42,42,0.9);"
      >
        {stats.map(s => (
          <div>
            <div class="font-display font-700 text-2xl text-gradient">{s.value}</div>
            <p class="text-brand-muted text-[10px] font-body uppercase tracking-widest mt-1">{s.label}</p>
          </div>
        ))}
      </div>

    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-24 pointer-events-none"
    style="background:linear-gradient(to top, #0D0D0D, transparent);">
  </div>
</section>