---
const stats = [
  { value: '15+', label: 'Años de experiencia' },
  { value: '24h', label: 'Urgencias siempre' },
  { value: '100%', label: 'Trabajos bajo norma' },
];
---

<section id="inicio" class="relative min-h-screen flex items-center overflow-hidden pt-20">

  <!-- Multi-layer dark background -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-dark via-brand-carbon to-brand-charcoal"></div>

  <!-- Subtle grid texture -->
  <div
    class="absolute inset-0 opacity-[0.045]"
    style="background-image:linear-gradient(rgba(180,180,180,.4) 1px,transparent 1px),linear-gradient(90deg,rgba(180,180,180,.4) 1px,transparent 1px);background-size:52px 52px;"
  ></div>

  <!-- Orange glow orb top-right -->
  <div class="absolute top-1/4 right-1/4 w-80 h-80 rounded-full pointer-events-none"
    style="background:radial-gradient(circle, rgba(255,140,0,0.07) 0%, transparent 70%);">
  </div>
  <!-- Second subtle orb bottom-left -->
  <div class="absolute bottom-1/4 left-1/6 w-96 h-96 rounded-full pointer-events-none"
    style="background:radial-gradient(circle, rgba(255,140,0,0.04) 0%, transparent 70%);">
  </div>

  <!-- Decorative large bolt bg -->
  <div class="absolute right-0 top-1/2 -translate-y-1/2 opacity-[0.025] pointer-events-none select-none overflow-hidden">
    <svg width="540" height="620" viewBox="0 0 24 24" fill="#FF8C00" aria-hidden="true">
      <path d="M13 2L4.09 12.97H11L10 22l8.91-10.97H13L13 2z"/>
    </svg>
  </div>

  <!-- Diagonal right panel -->
  <div class="absolute top-0 right-0 h-full w-2/5 pointer-events-none overflow-hidden">
    <div
      class="absolute inset-0 opacity-30"
      style="background:linear-gradient(135deg, transparent 30%, rgba(46,46,46,0.5) 100%);clip-path:polygon(30% 0%,100% 0%,100% 100%,0% 100%);"
    ></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-5 lg:px-10 py-24 lg:py-32">
    <div class="max-w-3xl">

      <!-- Eyebrow badge -->
      <div
        class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 opacity-0 animate-fade-in"
        style="animation-delay:.1s;animation-fill-mode:forwards;background:rgba(255,140,0,0.1);border:1px solid rgba(255,140,0,0.35);"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-brand-orange animate-pulse"></span>
        <span class="text-brand-orange text-[10px] font-body font-600 tracking-widest uppercase">
          Salto · Pergamino · Arrecifes y zona
        </span>
      </div>

      <!-- Headline -->
      <h1
        class="font-display font-900 text-5xl md:text-7xl lg:text-[82px] text-brand-white leading-[.92] tracking-tight mb-6 opacity-0 animate-fade-up"
        style="animation-delay:.2s;animation-fill-mode:forwards;"
      >
        SOLUCIONES<br />
        <span class="text-brand-orange" style="text-shadow:0 0 60px rgba(255,140,0,0.3);">ELÉCTRICAS</span><br />
        CON RESPALDO<br />
        INDUSTRIAL.
      </h1>

      <!-- Sub -->
      <p
        class="text-brand-silver text-lg md:text-xl font-body font-300 leading-relaxed max-w-xl mb-10 opacity-0 animate-fade-up"
        style="animation-delay:.35s;animation-fill-mode:forwards;"
      >
        Llevamos la máxima seguridad y eficiencia a tu hogar o comercio en
        <strong class="text-brand-light font-500">Salto y zona de influencia.</strong>
      </p>

      <!-- CTAs -->
      <div
        class="flex flex-col sm:flex-row gap-4 mb-16 opacity-0 animate-fade-up"
        style="animation-delay:.5s;animation-fill-mode:forwards;"
      >
        <a
          href="https://wa.me/5492474472101?text=Hola!%20Quiero%20solicitar%20un%20presupuesto."
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center justify-center gap-3 px-7 py-4 bg-brand-orange hover:bg-brand-orangeHover text-white font-display font-700 text-lg tracking-wide uppercase rounded transition-all duration-200 animate-pulse-glow"
        >
          <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Solicitar Presupuesto
        </a>
        <a
          href="#servicios"
          class="flex items-center justify-center gap-2 px-7 py-4 border border-brand-steel hover:border-brand-orange text-brand-light hover:text-brand-orange font-display font-600 text-lg tracking-wide uppercase rounded transition-all duration-200"
        >
          Ver Servicios
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <!-- Stats -->
      <div
        class="flex flex-wrap gap-8 border-t pt-8 opacity-0 animate-fade-up"
        style="animation-delay:.65s;animation-fill-mode:forwards;border-color:rgba(46,46,46,0.8);"
      >
        {stats.map(s => (
          <div>
            <span class="font-display font-800 text-3xl text-brand-orange">{s.value}</span>
            <p class="text-brand-muted text-[10px] font-body uppercase tracking-widest mt-0.5">{s.label}</p>
          </div>
        ))}
      </div>

    </div>
  </div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-20 bg-gradient-to-t from-brand-dark to-transparent pointer-events-none"></div>
</section>
