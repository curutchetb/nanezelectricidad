---
const WA = 'https://wa.me/5492474472101?text=Hola!%20Tengo%20una%20consulta%20sobre%20un%20trabajo%20eléctrico.';

const services = [
  {
    tag: 'Residencial',
    title: 'Instalaciones Hogareñas',
    desc: 'Tableros, cableados, tomas y llaves. Nuevas instalaciones y corrección de fallas con materiales de primera calidad.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>`,
  },
  {
    tag: 'Preventivo',
    title: 'Mantenimiento Preventivo',
    desc: 'Diagnóstico eléctrico integral, detección de fallas ocultas y optimización del consumo antes de que escalen.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63"/>`,
  },
  {
    tag: 'Imprevistos',
    title: 'Atención ante Imprevistos',
    desc: 'Cortes de luz, cortocircuitos y fallas urgentes. Respondemos rápido cuando más lo necesitás.',
    highlight: true,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>`,
  },
  {
    tag: 'Industrial',
    title: 'Comercios e Industrias',
    desc: 'Instalaciones trifásicas, tableros de comando, automatizaciones y mantenimiento en entornos de alta exigencia.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"/>`,
  },
];
---

<section id="servicios" class="relative py-24 lg:py-32 overflow-hidden" style="background:#0D0D0D;">

  <!-- Top accent -->
  <div class="absolute top-0 left-0 right-0 h-px"
    style="background:linear-gradient(90deg,transparent,rgba(255,140,0,.4),transparent);"></div>

  <div class="max-w-7xl mx-auto px-5 lg:px-10">

    <!-- Section header -->
    <div class="mb-14">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-8 h-0.5 rounded-full" style="background:#FF8C00;"></span>
        <span class="text-[10px] font-body font-600 tracking-widest uppercase" style="color:#FF8C00;">Nuestros Servicios</span>
      </div>
      <h2 class="font-display font-700 text-4xl md:text-5xl lg:text-6xl text-brand-white leading-tight">
        TODO LO QUE<br />
        <span class="text-gradient">NECESITÁS.</span>
      </h2>
      <p class="text-brand-silver font-body font-300 mt-4 max-w-lg text-base leading-relaxed">
        Electricista matriculado en Salto con experiencia en instalaciones residenciales,
        comerciales e industriales.
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {services.map(s => (
        <article
          class="card-glow relative p-7 lg:p-8 rounded-2xl border overflow-hidden"
          style={s.highlight
            ? 'background:rgba(255,140,0,0.06);border-color:rgba(255,140,0,0.2);'
            : 'background:#111111;border-color:#2A2A2A;'}
        >
          <!-- Corner accent for highlighted -->
          {s.highlight && (
            <div class="absolute top-0 right-0 w-24 h-24 pointer-events-none"
              style="background:radial-gradient(circle at top right, rgba(255,140,0,0.15) 0%, transparent 70%);">
            </div>
          )}

          <!-- Icon -->
          <div
            class="w-11 h-11 rounded-xl flex items-center justify-center mb-5"
            style={s.highlight ? 'background:rgba(255,140,0,0.15);' : 'background:#1A1A1A;'}
          >
            <svg
              class="w-5 h-5"
              style={s.highlight ? 'color:#FF8C00;' : 'color:#777777;'}
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              viewBox="0 0 24 24"
              aria-hidden="true"
              set:html={s.icon}
            />
          </div>

          <!-- Tag -->
          <span
            class="inline-block text-[9px] font-body font-600 tracking-widest uppercase px-2.5 py-1 rounded-full mb-3"
            style={s.highlight
              ? 'background:rgba(255,140,0,0.2);color:#FF8C00;'
              : 'background:#1A1A1A;color:#777777;'}
          >
            {s.tag}
          </span>

          <h3
            class="font-display font-600 text-xl lg:text-2xl mb-2 tracking-tight"
            style={s.highlight ? 'color:#FFA733;' : 'color:#E0E0E0;'}
          >
            {s.title}
          </h3>
          <p class="text-brand-muted text-sm font-body font-300 leading-relaxed">{s.desc}</p>
        </article>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-10 text-center">
      <p class="text-brand-muted text-sm mb-3 font-body">¿Tenés una consulta específica?</p>
      <a
        href={WA}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-brand-orange hover:text-brand-light font-body font-500 text-sm underline underline-offset-4 transition-colors duration-200"
      >
        Escribinos por WhatsApp →
      </a>
    </div>
  </div>
</section>