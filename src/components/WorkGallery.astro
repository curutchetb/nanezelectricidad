---
const photos = [
  {
    src: './trabajando1.webp',
    alt: 'Técnico electricista de Ñañez & Co. trabajando en instalación industrial en altura en Salto, Buenos Aires',
    caption: 'Instalación en altura con equipo certificado',
  },
  {
    src: './trabajando2.webp',
    alt: 'Electricista matriculado de Ñañez & Co. en mantenimiento eléctrico industrial',
    caption: 'Mantenimiento en planta — protocolos industriales',
  },
  {
    src: './sergio1.webp',
    alt: 'Sergio de Ñañez & Co. realizando ajustes en tablero eléctrico residencial',
    caption: 'Precisión en tableros y protecciones',
  },
  {
    src: './sergio2.webp',
    alt: 'Sergio trabajando con herramientas profesionales de medición eléctrica',
    caption: 'Diagnóstico y mediciones de seguridad',
  },
  {
    src: './trabajando3.webp',
    alt: 'Técnico electricista con arnés de seguridad realizando trabajo en altura',
    caption: 'Trabajo en altura bajo normativa AEA',
  },
];
---

<section id="trabajos" class="relative py-24 lg:py-32 overflow-hidden" style="background:#111111;">
  <div class="absolute top-0 left-0 right-0 h-px" style="background:linear-gradient(90deg,transparent,rgba(255,140,0,.25),transparent);"></div>

  <div class="max-w-7xl mx-auto px-5 lg:px-10">
    
    <div class="mb-14">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-8 h-0.5 rounded-full" style="background:#FF8C00;"></span>
        <span class="text-[10px] font-body font-600 tracking-widest uppercase" style="color:#FF8C00;">Experiencia en Acción</span>
      </div>
      <h2 class="font-display font-700 text-4xl md:text-5xl lg:text-6xl text-brand-white leading-tight">
        TRABAJOS<br />
        <span class="text-gradient">REALES.</span>
      </h2>
      <p class="text-brand-silver font-body font-300 mt-4 max-w-lg text-base leading-relaxed">
        Nuestra trayectoria en Salto habla por sí sola. Galería de instalaciones industriales, mantenimiento y seguridad eléctrica.
      </p>
    </div>

    <div class="columns-1 md:columns-2 lg:columns-3 gap-5 space-y-5">
      {photos.map(photo => (
        <div class="break-inside-avoid group relative rounded-2xl overflow-hidden border border-[#2A2A2A] bg-[#1A1A1A]">
          
          <img 
            src={photo.src} 
            alt={photo.alt} 
            class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105" 
            loading="lazy"
            decoding="async"
          />
          
          <div class="absolute bottom-0 left-0 right-0 p-5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-gradient-to-t from-black/80 to-transparent">
            <p class="text-white text-sm font-body font-400 leading-snug">
              {photo.caption}
            </p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-wrap gap-3 justify-center">
      {['Seguridad Certificada', 'Normativa AEA', 'Trabajos en Altura', 'Matriculado'].map(b => (
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-[10px] font-600 tracking-wider uppercase border border-[#2A2A2A] bg-[#1A1A1A] text-[#A8A8A8]">
          <span class="w-1.5 h-1.5 rounded-full" style="background:#FF8C00;"></span>
          {b}
        </span>
      ))}
    </div>

  </div>
</section>