---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Ñañez & Co. Electricidad | Salto, Buenos Aires',
  description = 'Soluciones eléctricas residenciales y comerciales con respaldo industrial. Instalaciones, mantenimiento y urgencias 24h en Salto, Pergamino, Arrecifes y zona.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/logo.png" />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
      :root {
        --c-carbon:   #1A1A1A;
        --c-charcoal: #222222;
        --c-dark:     #141414;
        --c-steel:    #2E2E2E;
        --c-mid:      #3A3A3A;
        --c-silver:   #B0B0B0;
        --c-light:    #E8E8E8;
        --c-white:    #F5F5F5;
        --c-orange:   #FF8C00;
        --c-orange-h: #E67E00;
        --c-muted:    #888888;
      }
      html { background-color: var(--c-dark); }
      body { font-family: 'DM Sans', 'Segoe UI', sans-serif; color: var(--c-light); }
      ::selection { background: var(--c-orange); color: #111; }
      ::-webkit-scrollbar { width: 5px; }
      ::-webkit-scrollbar-track { background: var(--c-carbon); }
      ::-webkit-scrollbar-thumb { background: var(--c-steel); border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--c-orange); }
    </style>
  </head>
  <body class="bg-brand-dark antialiased">
    <slot />
  </body>
</html>
